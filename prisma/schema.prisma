generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ResponseType{
  JOIN
  SKIP
  RESERVE
}

model LunchResponse {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  slackId   String
  slackName String
  response  ResponseType
  lunchDate String

  @@unique([slackId, lunchDate])
}
